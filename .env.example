# ============================================================
# Clawdboss Environment Variables
# Copy this file to ~/.openclaw/.env and fill in your values
# ============================================================

# --- LLM Provider ---
# GitHub Copilot proxy (if using copilot-api)
COPILOT_API_KEY=your-copilot-key-here

# OpenAI (for image gen, whisper, embeddings)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic (direct, if not using Copilot proxy)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini
# GEMINI_API_KEY=your-gemini-key-here

# --- Channels ---
# Discord bot token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# --- Search ---
# Brave Search API (from https://brave.com/search/api/)
BRAVE_API_KEY=your-brave-api-key-here

# --- Skills (Optional) ---
# ElevenLabs TTS & Music
# ELEVENLABS_API_KEY=sk_your-elevenlabs-key-here

# Nano Banana Pro (Gemini image gen)
# NANO_BANANA_API_KEY=your-key-here

# --- Memory ---
# OpenAI embedding key for memory-hybrid (can be same as OPENAI_API_KEY)
EMBEDDING_API_KEY=sk-your-openai-key-here

# --- Gateway ---
# Auto-generated during setup — change if needed
GATEWAY_AUTH_TOKEN=change-me-to-a-random-string
